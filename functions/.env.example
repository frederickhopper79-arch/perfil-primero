APP_URL=https://perfil-primero.web.app
FUNCTIONS_BASE_URL=https://us-central1-perfil-primero.cloudfunctions.net

# Mercado Pago (Chile) — obtener en mercadopago.com.ar/developers
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=...

# Stripe (fallback internacional)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WORKER_PRICE_ID=price_...

# IA — Groq (principal)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# IA — Gemini (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-001

# Email transaccional — SendGrid
# Obtener en app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG....

# Web Push Notifications (VAPID)
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@perfil-primero.cl
